# ATDM environment configuration template (host context).
# Copy to .env.local and fill in real values. .env.local is gitignored.
#
# These values are for tools running on the developer's laptop (atdm CLI,
# pytest invoked from the host, browser). Inside the compose network,
# services address each other by service name and container-internal port —
# the docker-compose.yml sets those values directly on each container.
#
# Host port mapping is documented in planning/PLAN.md Phase 1. We use
# non-default host ports to avoid collisions with other local stacks.

# ---------------------------------------------------------------------------
# ATDM agent (FastAPI) — host port 18001 -> container 8001
# ---------------------------------------------------------------------------
ATDM_API_URL=http://localhost:18001
ATDM_API_TOKEN=dev-token-change-me

# Planner mode — keep "rule" for MVP. "llm" returns HTTP 501 in MVP.
ATDM_PLANNER=rule

# Where Playwright JSON and pytest module fixtures are written.
ATDM_FIXTURE_DIR=./automation/fixtures

# ---------------------------------------------------------------------------
# Target SUT (FastAPI + Postgres) — host port 18000 -> container 8000
# ---------------------------------------------------------------------------
TARGET_SUT_URL=http://localhost:18000

# ---------------------------------------------------------------------------
# Postgres — host port 55432 -> container 5432
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_USER=atdm
POSTGRES_PASSWORD=change-me
POSTGRES_DB=target_healthcare

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
#   API     host port 19000 -> container 9000
#   Console host port 19001 -> container 9001
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=http://localhost:19000
MINIO_CONSOLE_URL=http://localhost:19001
MINIO_ROOT_USER=atdm
MINIO_ROOT_PASSWORD=change-me-too
MINIO_BUCKET_CATALOG=atdm-catalog
MINIO_BUCKET_AUDIT=atdm-audit
MINIO_BUCKET_FIXTURES=atdm-fixtures
